---
import Layout from "@/layouts/Layout.astro"
import { SITE_DESCRIPTION, PROFILE } from "@/consts.ts"

function getFavicon(url: string) {
  const host = new URL(url).hostname
  return `https://www.google.com/s2/favicons?domain=${host}&sz=64`
}
---

<Layout title="About | leekoho" description="关于 leekoho 的个人介绍、居住城市与 GitHub 信息。">
  <section class="about-shell">
    <div class="about-hero">
      <p class="about-kicker">About</p>
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <h1 class="about-title">About Me</h1>
      </div>
      <p class="about-summary">这里放一些关于我自己的信息，也作为博客之外的一点补充。</p>
    </div>

    <div class="about-grid">
      <article class="about-card about-card-primary">
        <p class="about-card-label">个人介绍</p>
        <h2 class="about-name">{PROFILE.name}</h2>
        <p class="about-role">{PROFILE.tags.join(" / ")}</p>
        <p class="about-copy">
          {PROFILE.description || SITE_DESCRIPTION}
        </p>
      </article>

      <article class="about-card">
        <p class="about-card-label">居住城市</p>
        <p class="about-meta">{PROFILE.city}</p>
        <p class="about-hint">现在常住在这里，写代码、写文章，也把日常生活安放在这座城市里。</p>
      </article>

      <article class="about-card">
        <p class="about-card-label">在线链接</p>
        <ul class="about-links">
          {
            PROFILE.links.map((item) => (
              <li>
                <a href={item.url} target="_blank" rel="noreferrer" class="about-link group">
                  <span class="about-link-main">
                    <img src={getFavicon(item.url)} alt="232" class="size-4" />
                    <span>{item.label}</span>
                  </span>
                  <span class="about-link-arrow" aria-hidden="true">
                    ↗
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </section>
</Layout>

<style>
  @reference "@/styles/tailwind.css";

  .about-shell {
    @apply relative overflow-hidden px-4 pbs-6 pbe-14 sm:px-6 lg:px-10 lg:pbs-10 lg:pbe-24;
  }

  .about-hero,
  .about-grid {
    @apply relative z-10;
  }

  .about-hero {
    @apply mbe-10 max-w-3xl space-y-4 lg:mbe-14;
  }

  .about-kicker {
    @apply text-xs font-semibold tracking-[0.24em] text-teal-600 uppercase dark:text-teal-300;
  }

  .about-title {
    @apply text-4xl leading-none font-semibold tracking-tighter text-zinc-950 sm:text-5xl dark:text-white;
  }

  .about-summary {
    @apply max-w-2xl text-sm leading-7 text-zinc-500 dark:text-zinc-400;
  }

  .about-grid {
    @apply grid gap-4 md:grid-cols-2;
  }

  .about-card {
    @apply rounded-[1.75rem] border border-zinc-200/80 bg-white/85 p-6 shadow-[0_16px_50px_rgba(15,23,42,0.05)] backdrop-blur-sm dark:border-white/10 dark:bg-zinc-900/75 dark:shadow-[0_18px_50px_rgba(0,0,0,0.28)];
  }

  .about-card-primary {
    @apply md:col-span-2;
    @apply bg-[linear-gradient(135deg,rgba(255,255,255,0.95),rgba(240,253,250,0.9)_45%,rgba(244,244,245,0.92))];
    @apply dark:bg-[linear-gradient(135deg,rgba(24,24,27,0.92),rgba(15,118,110,0.14)_55%,rgba(24,24,27,0.82))];
  }

  .about-card-label {
    @apply mbe-4 text-xs font-semibold tracking-[0.22em] text-zinc-400 uppercase dark:text-zinc-500;
  }

  .about-name {
    @apply text-3xl font-semibold tracking-tight text-zinc-950 dark:text-white;
  }

  .about-role {
    @apply mbs-2 text-sm font-medium tracking-[0.18em] text-teal-700 dark:text-teal-300;
  }

  .about-copy {
    @apply mbs-5 max-w-2xl text-sm leading-7 text-zinc-600 dark:text-zinc-300;
  }

  .about-meta {
    @apply text-2xl font-medium tracking-tight text-zinc-900 dark:text-zinc-100;
  }

  .about-hint {
    @apply mbs-3 text-sm leading-7 text-zinc-500 dark:text-zinc-400;
  }

  .about-links {
    @apply m-0 list-none space-y-3 p-0;
  }

  .about-link {
    @apply flex items-center justify-between gap-4 rounded-2xl border border-zinc-200/80 px-4 py-3 text-sm text-zinc-700 no-underline transition hover:-translate-y-0.5 hover:border-teal-200 hover:text-teal-700 dark:border-white/10 dark:text-zinc-200 dark:hover:border-teal-400/30 dark:hover:text-teal-200;
  }

  .about-link-main {
    @apply flex items-center gap-3;
  }

  .about-link-arrow {
    @apply text-zinc-400 transition group-hover:text-current;
  }
</style>
