---
import Layout from "@/layouts/Layout.astro"
import { SITE_DESCRIPTION, PROFILE } from "@/consts.ts"

function getFavicon(url: string) {
  const host = new URL(url).hostname
  return `https://www.google.com/s2/favicons?domain=${host}&sz=64`
}
---

<Layout title="About | leekoho" description="关于 leekoho 的个人介绍、居住城市与 GitHub 信息。">
  <section class="about-shell">
    <div class="about-hero">
      <p class="section-kicker">About</p>
      <div class="about-hero-row">
        <h1 class="section-title">About Me</h1>
      </div>
      <p class="section-summary">这里放一些关于我自己的信息，也作为博客之外的一点补充。</p>
    </div>

    <div class="about-grid">
      <article class="about-card ui-card-border about-card-primary">
        <p class="about-card-label subtle-copy">个人介绍</p>
        <h2 class="about-name">{PROFILE.name}</h2>
        <p class="about-role accent-copy">{PROFILE.tags.join(" / ")}</p>
        <p class="about-copy">
          {PROFILE.description || SITE_DESCRIPTION}
        </p>
      </article>

      <article class="about-card ui-card-border">
        <p class="about-card-label subtle-copy">居住城市</p>
        <p class="about-meta">{PROFILE.city}</p>
        <p class="about-hint muted-copy">
          现在常住在这里，写代码、写文章，也把日常生活安放在这座城市里。
        </p>
      </article>

      <article class="about-card ui-card-border">
        <p class="about-card-label subtle-copy">在线链接</p>
        <ul class="about-links">
          {
            PROFILE.links.map((item) => (
              <li>
                <a
                  href={item.url}
                  target="_blank"
                  rel="noreferrer"
                  class="about-link ui-card-border group"
                >
                  <span class="about-link-main">
                    <img src={getFavicon(item.url)} alt="232" class="about-link-icon" />
                    <span>{item.label}</span>
                  </span>
                  <span class="about-link-arrow subtle-copy" aria-hidden="true">
                    ↗
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </article>

      {
        PROFILE.uses.map((group) => (
          <article class="about-card ui-card-border md:col-span-2">
            <div>
              <p class="about-card-label subtle-copy">{group.category}</p>
              <ul class="uses-list">
                {group.items.map((item) => (
                  <li class="uses-list-item">
                    <h4 class="uses-item-name">{item.name}</h4>
                    {item.description && (
                      <p class="uses-item-description muted-copy">{item.description}</p>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  @reference "@/styles/tailwind.css";

  .about-shell {
    @apply relative overflow-hidden px-4 pbs-6 pbe-14 sm:px-6 lg:px-10 lg:pbs-10 lg:pbe-24;
  }

  .about-hero,
  .about-grid {
    @apply relative z-10;
  }

  .about-hero {
    @apply mbe-10 max-w-3xl space-y-4 lg:mbe-14;
  }

  .about-hero-row {
    @apply flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between;
  }

  .about-grid {
    @apply grid gap-4 md:grid-cols-2;
  }

  .about-card {
    @apply bg-panel/85 rounded-3xl p-6 backdrop-blur-md;
    box-shadow: 0 16px 50px rgba(15, 23, 42, 0.05);
  }

  .about-card-primary {
    @apply md:col-span-2;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.95),
      rgba(240, 253, 250, 0.9) 45%,
      rgba(244, 244, 245, 0.92)
    );
  }

  :global(.dark) .about-card-primary {
    background: linear-gradient(
      135deg,
      rgba(24, 24, 27, 0.92),
      rgba(15, 118, 110, 0.14) 55%,
      rgba(24, 24, 27, 0.82)
    );
  }

  .about-card-label {
    @apply mbe-4 text-xs font-semibold tracking-widest uppercase;
  }

  .about-name {
    @apply text-foreground text-3xl font-semibold tracking-tight;
  }

  .about-role {
    @apply mbs-2 text-sm font-medium tracking-wider;
  }

  .about-copy {
    @apply text-foreground-soft mbs-5 max-w-2xl text-sm leading-7;
  }

  .about-meta {
    @apply text-foreground text-2xl font-medium tracking-tight;
  }

  .about-hint {
    @apply mbs-3 text-sm leading-7;
  }

  .about-links {
    @apply m-0 list-none space-y-3 p-0;
  }

  .about-link {
    @apply text-foreground-soft flex items-center justify-between gap-4 rounded-2xl px-4 py-3 text-sm no-underline transition;
    background: transparent;
  }

  .about-link-main {
    @apply flex items-center gap-3;
  }

  .about-link-icon {
    @apply size-4;
  }

  .about-link-arrow {
    @apply transition group-hover:text-current;
  }

  .about-link:hover {
    @apply border-accent/25 text-accent-strong -translate-y-0.5;
  }

  .uses-card-label {
    @apply border-border mbe-6 border-b pb-2 text-xs font-semibold tracking-widest uppercase;
  }

  .uses-list {
    @apply m-0 list-none space-y-6 p-0;
  }

  .uses-list-item {
    @apply flex flex-col gap-1;
  }

  .uses-item-name {
    @apply text-foreground text-lg font-medium tracking-tight;
  }

  .uses-item-description {
    @apply text-sm leading-relaxed;
  }
</style>
