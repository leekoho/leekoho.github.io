---
import { Lock } from "@lucide/astro"

interface Props {
  password?: string
}

const { password } = Astro.props

let html = ""
html = await Astro.slots.render("default")

let cipherHTML = ""
let saltStr = ""
let ivStr = ""
let authHash = ""

if (password) {
  const bufToHex = (buf: ArrayBuffer) =>
    Array.from(new Uint8Array(buf))
      .map((b) => b.toString(16).padStart(2, "0"))
      .join("")

  // 生成随机盐和初始向量（各 128 位）
  const salt = crypto.getRandomValues(new Uint8Array(16))
  const iv = crypto.getRandomValues(new Uint8Array(16))

  // 1. 导入密码为 PBKDF2 原材料
  const keyMaterial = await crypto.subtle.importKey(
    "raw",
    new TextEncoder().encode(password),
    "PBKDF2",
    false,
    ["deriveKey"],
  )

  // 2. PBKDF2 推导 AES-CBC 256 位密钥（SHA-256 + 10000 次迭代）
  const aesKey = await crypto.subtle.deriveKey(
    { name: "PBKDF2", salt, iterations: 10000, hash: "SHA-256" },
    keyMaterial,
    { name: "AES-CBC", length: 256 },
    true,
    ["encrypt"],
  )

  // 3. AES-CBC 加密 HTML
  const encryptedBuffer = await crypto.subtle.encrypt(
    { name: "AES-CBC", iv },
    aesKey,
    new TextEncoder().encode(html),
  )

  // 4. 导出密钥 → Hex → SHA-256 凭证哈希（与客户端完全对称）
  const keyBytes = await crypto.subtle.exportKey("raw", aesKey)
  const keyHex = bufToHex(keyBytes)
  const hashBuffer = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(keyHex))

  // Buffer.from 在 Node.js 中处理大文章比 btoa+spread 更安全（无 stack overflow 风险）
  cipherHTML = Buffer.from(encryptedBuffer).toString("base64")
  saltStr = bufToHex(salt.buffer)
  ivStr = bufToHex(iv.buffer)
  authHash = bufToHex(hashBuffer)
}
---

{
  password ? (
    <encrypted-content
      data-cipher={cipherHTML}
      data-salt={saltStr}
      data-iv={ivStr}
      data-hash={authHash}
    >
      <div class="not-prose border-border shadow-card bg-background-muted my-8 space-y-6 rounded-lg border p-6">
        <div class="space-y-3 text-center">
          <Lock class="text-muted mx-auto size-8" />
          <div class="flex flex-col gap-y-1">
            <h3 class="text-foreground text-lg font-medium">此文章已加密</h3>
            <p class="text-muted text-sm">请输入密码以查看内容</p>
          </div>
        </div>

        <div class="mx-auto flex max-w-sm items-center space-x-3">
          <input
            type="password"
            id="encrypt-pwd"
            placeholder="输入密码"
            class="border-border bg-background placeholder:text-muted focus-visible:ring-accent h-10 w-full rounded-full border px-4 py-2 text-sm transition-all focus-visible:ring-2 focus-visible:outline-none"
          />
          <button
            id="encrypt-btn"
            class="shadow-button bg-foreground text-background inline-flex h-10 shrink-0 cursor-pointer items-center justify-center rounded-full px-6 py-2 text-sm font-medium transition-opacity hover:opacity-90 disabled:pointer-events-none disabled:opacity-50"
          >
            解锁
          </button>
        </div>
        <p id="encrypt-error" class="mt-3 hidden text-center text-sm text-red-500">
          密码错误，请重试
        </p>
      </div>
    </encrypted-content>
  ) : (
    <Fragment set:html={html} />
  )
}

<script>
  const hexToBuffer = (hex: string) =>
    Uint8Array.from(hex.match(/.{2}/g)!.map((b) => parseInt(b, 16)))

  const bufferToHex = (buf: ArrayBuffer) =>
    Array.from(new Uint8Array(buf))
      .map((b) => b.toString(16).padStart(2, "0"))
      .join("")

  const base64ToBuffer = (b64: string) => Uint8Array.from(atob(b64), (c) => c.charCodeAt(0))

  class EncryptedContent extends HTMLElement {
    connectedCallback() {
      const cipherText = this.dataset.cipher
      const saltStr = this.dataset.salt
      const ivStr = this.dataset.iv
      const authHash = this.dataset.hash

      if (!cipherText || !authHash || !saltStr || !ivStr) return

      const btn = this.querySelector("#encrypt-btn") as HTMLButtonElement
      const input = this.querySelector("#encrypt-pwd") as HTMLInputElement
      const errorMsg = this.querySelector("#encrypt-error")

      // 预先解析 salt / iv，避免每次 unlock 重复解析
      const saltBuffer = hexToBuffer(saltStr)
      const ivBuffer = hexToBuffer(ivStr)

      const unlock = async () => {
        const pwd = input.value
        if (!pwd) return

        btn.disabled = true
        btn.innerText = "解密中..."
        errorMsg?.classList.add("hidden")

        try {
          const enc = new TextEncoder()

          // 1. 导入原始密码为 PBKDF2 的原材料
          const keyMaterial = await crypto.subtle.importKey(
            "raw",
            enc.encode(pwd),
            "PBKDF2",
            false,
            ["deriveKey"],
          )

          // 2. PBKDF2 推导 AES-CBC 256 位密钥（SHA-256 / 10000 次，与构建端完全对齐）
          const aesKey = await crypto.subtle.deriveKey(
            { name: "PBKDF2", salt: saltBuffer, iterations: 10000, hash: "SHA-256" },
            keyMaterial,
            { name: "AES-CBC", length: 256 },
            true, // extractable=true 以便导出字节做凭证哈希校验
            ["decrypt"],
          )

          // 3. 导出密钥字节，转为 Hex 字符串，对 Hex 字符串求哈希，与构建端方式完全对齐
          const keyBytes = await crypto.subtle.exportKey("raw", aesKey)
          const keyHex = bufferToHex(keyBytes)
          const hashBuffer = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(keyHex))
          const inputHash = bufferToHex(hashBuffer)

          if (inputHash !== authHash) {
            errorMsg?.classList.remove("hidden")
            btn.disabled = false
            btn.innerText = "解锁"
            return
          }

          // 4. 密码正确，AES-CBC 解密（CryptoJS .toString() 输出纯 Base64 密文）
          let decryptedBuffer: ArrayBuffer
          try {
            decryptedBuffer = await crypto.subtle.decrypt(
              { name: "AES-CBC", iv: ivBuffer },
              aesKey,
              base64ToBuffer(cipherText),
            )
          } catch (decryptErr) {
            console.error(
              "[EncryptedContent] decrypt() failed — 凭证校验通过但解密异常，请检查两端 IV / 加密模式是否对齐:",
              decryptErr,
            )
            throw decryptErr
          }

          if (decryptedBuffer.byteLength === 0) throw new Error("解密结果为空")
          this.outerHTML = new TextDecoder().decode(decryptedBuffer)
        } catch (e) {
          console.error(e)
          errorMsg?.classList.remove("hidden")
          btn.disabled = false
          btn.innerText = "解锁"
        }
      }

      btn?.addEventListener("click", unlock)
      input?.addEventListener("keypress", (e) => {
        if (e.key === "Enter") unlock()
      })
      input?.addEventListener("input", () => {
        errorMsg?.classList.add("hidden")
      })
    }
  }

  customElements.define("encrypted-content", EncryptedContent)
</script>
