---
import { type CollectionEntry, getCollection } from "astro:content"

type Post = CollectionEntry<"posts">

const allPosts = (
  await getCollection("posts", ({ data }) => (import.meta.env.PROD ? data.draft !== true : true))
).toSorted((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

const groups = new Map<number, Post[]>()

allPosts.forEach((post) => {
  const year = post.data.pubDate.getFullYear()
  if (!groups.has(year)) {
    groups.set(year, [])
  }
  groups.get(year)!.push(post)
})
---

<main class="post-shell">
  {
    allPosts.length === 0 ? (
      <p class="post-empty">No posts yet.</p>
    ) : (
      <>
        <section class="post-hero" aria-label="Archive overview">
          <p class="section-kicker">Blog</p>

          <div class="post-hero-row">
            <h1 class="section-title">Posts</h1>
          </div>

          <p class="section-summary">这里主要记录开发中的经验、问题拆解和一些可复用的实践。</p>
        </section>

        <div class="post-groups">
          {Array.from(groups).map(([year, yearPosts]) => (
            <section class="post-group" aria-labelledby={`post-year-${year}`}>
              <div class="post-group-year">
                <h2 class="year-heading" id={`post-year-${year}`}>
                  {year}
                </h2>
              </div>

              <ul class="post-group-list">
                {yearPosts.map((post) => (
                  <li class="post-item">
                    <a href={`/posts/${post.id}`} class="post-link group">
                      <span class="post-title">{post.data.title}</span>
                      <time
                        class="post-date"
                        data-post-date="short"
                        datetime={post.data.pubDate.toISOString()}
                      >
                        {post.data.pubDate.toISOString().slice(5, 10)}
                      </time>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </>
    )
  }
</main>

<script is:inline>
  const formatPostDates = () => {
    const shortFormatter = new Intl.DateTimeFormat(undefined, {
      month: "short",
      day: "numeric",
    })
    const longFormatter = new Intl.DateTimeFormat(undefined, {
      year: "numeric",
      month: "short",
      day: "2-digit",
    })

    document.querySelectorAll("[data-post-date]").forEach((element) => {
      const datetime = element.getAttribute("datetime")
      if (!datetime) {
        return
      }

      const date = new Date(datetime)
      if (Number.isNaN(date.getTime())) {
        return
      }

      element.textContent =
        element.getAttribute("data-post-date") === "long"
          ? longFormatter.format(date)
          : shortFormatter.format(date)
    })
  }

  formatPostDates()
</script>

<style>
  @reference "@/styles/tailwind.css";

  .post-shell {
    @apply relative overflow-hidden px-4 pbs-6 pbe-14 sm:px-6 lg:px-10 lg:pbs-10 lg:pbe-24;
  }

  .post-empty {
    @apply text-muted py-8;
  }

  .post-hero {
    @apply relative z-10 mbe-10 space-y-4 lg:mbe-14;
  }

  .post-hero-row {
    @apply flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between;
  }

  .post-groups {
    @apply relative z-10 space-y-14;
  }

  .post-group {
    @apply space-y-3 lg:flex lg:space-y-0 lg:gap-x-4;
  }

  .post-group-year {
    @apply flex items-center gap-3 lg:w-24 lg:flex-none lg:self-start lg:pbs-2;
  }

  .post-group-list {
    @apply relative lg:flex-1;
  }

  .year-heading {
    @apply text-foreground/25 text-2xl font-semibold lg:self-start lg:pbs-2;
  }

  .post-item {
    @apply relative list-none;
  }

  .post-item::after {
    content: "";
    @apply absolute right-0 bottom-0 left-0 h-px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
  }

  .post-link {
    @apply relative flex flex-col gap-2 py-5 no-underline sm:flex-row sm:items-center sm:justify-between;
  }

  .post-link::before {
    content: "";
    @apply pointer-events-none absolute -inset-x-3 inset-y-1 rounded-2xl opacity-0 transition duration-300;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-accent) 6%, transparent),
      color-mix(in srgb, var(--color-panel) 18%, transparent) 38%,
      color-mix(in srgb, var(--color-background-muted) 86%, white)
    );
  }

  .post-link:hover,
  .post-link:focus-visible {
    @apply -translate-y-px;
  }

  .post-link:hover::before,
  .post-link:focus-visible::before {
    @apply opacity-100;
  }

  .post-link:focus-visible {
    @apply outline-none;
  }

  .post-title {
    @apply text-foreground relative z-10 text-base leading-6 font-medium tracking-tight transition duration-300 sm:ps-5;
  }

  .post-link:hover .post-title,
  .post-link:focus-visible .post-title {
    @apply translate-x-0.5;
    @apply text-accent-strong;
  }

  .post-date {
    @apply text-subtle relative z-10 text-xs font-medium tracking-wider tabular-nums transition duration-300 sm:ms-8 sm:text-right;
  }

  .post-link:hover .post-date,
  .post-link:focus-visible .post-date {
    @apply text-muted;
  }
</style>
