---
import { Image } from "astro:assets"
import ModeToggle from "./ModeToggle.astro"
import SonGokuImage from "@/assets/SonGoku.jpeg"

const { pathname } = Astro.url

const normalizePath = (value: string) => {
  if (value === "/") {
    return value
  }

  return value.replace(/\/$/, "")
}

const isActive = (href: string) => {
  const normalizedHref = normalizePath(href)
  const normalizedPathname = normalizePath(pathname)

  if (normalizedHref === "/") {
    return normalizedPathname === "/"
  }

  return (
    normalizedHref === normalizedPathname || normalizedPathname.startsWith(`${normalizedHref}/`)
  )
}
---

<header class="header">
  <a href="/">
    <Image src={SonGokuImage} alt="SonGoku" width="40" height="40" class="avatar" />
  </a>

  <nav class="nav">
    {
      [
        ["Blog", "/posts", "_self"],
        // ["Tools", "/tools", "_self"],
        ["About", "/about", "_self"],
        // ['Github', GITHUB_URL, '_blank'],
        ["Feed", "/feed", "_blank"],
      ].map(([title, url, target]) => (
        <a href={url} class:list={["nav-link", { active: isActive(url) }]} target={target}>
          {title}
        </a>
      ))
    }
  </nav>

  <ModeToggle />
</header>

<script is:inline>
  const storageKey = "theme-preference"
  const resolveTheme = (preference) => {
    if (preference === "system") {
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
    }

    return preference
  }

  const themeController = {
    getPreference() {
      if (typeof localStorage === "undefined") {
        return "system"
      }

      return localStorage.getItem(storageKey) ?? "system"
    },

    apply(preference) {
      const resolvedTheme = resolveTheme(preference)
      document.documentElement.dataset.themePreference = preference
      document.documentElement.classList.toggle("dark", resolvedTheme === "dark")

      if (typeof localStorage !== "undefined") {
        localStorage.setItem(storageKey, preference)
      }

      window.dispatchEvent(new CustomEvent("theme-change", { detail: { preference } }))
    },
  }

  window.__themeController = themeController
  themeController.apply(themeController.getPreference())

  const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)")
  const handleSystemThemeChange = () => {
    if (themeController.getPreference() === "system") {
      themeController.apply("system")
    }
  }

  mediaQuery.addEventListener?.("change", handleSystemThemeChange)
</script>

<style>
  @reference "@/styles/tailwind.css";

  .header {
    @apply relative isolate z-20 flex items-center justify-between p-4 sm:px-6 lg:px-10;
  }

  .header::before {
    content: "";
    @apply pointer-events-none absolute inset-x-4 -top-14 h-56 rounded-3xl blur-3xl sm:inset-x-6;
    background:
      radial-gradient(
        circle at 18% 18%,
        color-mix(in srgb, var(--color-accent) 22%, transparent),
        transparent 34%
      ),
      radial-gradient(
        circle at 78% 12%,
        color-mix(in srgb, var(--color-foreground) 10%, transparent),
        transparent 32%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-background) 82%, transparent),
        transparent 78%
      );
    z-index: 0;
  }

  .header > * {
    @apply relative z-10;
  }

  @media (min-width: 1024px) {
    .header::before {
      @apply h-64;
      top: -4.5rem;
    }
  }

  .avatar {
    @apply border-border bg-panel/90 size-10 rounded-full border p-0.5 backdrop-blur-md;
    box-shadow: var(--shadow-card);
  }

  .nav {
    @apply border-border bg-panel/90 flex rounded-full border px-3 text-sm font-medium backdrop-blur-md;
    box-shadow: var(--shadow-card);
  }

  .nav-link {
    @apply text-foreground-soft relative block px-3 py-2 no-underline transition;
  }

  .nav-link.active {
    @apply text-accent-strong;
  }

  .nav-link.active::after {
    @apply absolute inset-x-1 -bottom-px h-px content-[''];
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--color-accent) 42%, transparent),
      transparent
    );
  }

  .nav-link:hover {
    @apply text-accent-strong;
  }
</style>
