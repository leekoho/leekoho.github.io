---
const options = [
  { value: "light", label: "Light" },
  { value: "dark", label: "Dark" },
  { value: "system", label: "System" },
]
---

<details class="theme-switcher" data-theme-switcher>
  <summary class="theme-trigger">
    <svg
      aria-hidden="true"
      class="size-4"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.8"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.5 6.5 0 0 0 9.8 9.8Z"></path>
    </svg>
    <span class="sr-only">切换主题</span>
  </summary>

  <div class="theme-menu">
    {
      options.map((option) => (
        <button class="theme-option" data-theme-option={option.value} type="button">
          <span>{option.label}</span>
          <span aria-hidden="true" class="theme-check">
            <svg
              class="size-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="m5 12 5 5L20 7" />
            </svg>
          </span>
        </button>
      ))
    }
  </div>
</details>

<script is:inline>
  const initializeThemeSwitcher = (switcher) => {
    if (!switcher || switcher.dataset.ready === "true") {
      return
    }

    const syncSelection = () => {
      const currentPreference = window.__themeController?.getPreference?.() ?? "system"
      switcher.dataset.theme = currentPreference

      switcher.querySelectorAll("[data-theme-option]").forEach((button) => {
        const isActive = button.dataset.themeOption === currentPreference
        button.dataset.active = isActive ? "true" : "false"
        button.setAttribute("aria-pressed", isActive ? "true" : "false")
      })
    }

    switcher.querySelectorAll("[data-theme-option]").forEach((button) => {
      button.addEventListener("click", () => {
        const preference = button.dataset.themeOption ?? "system"
        window.__themeController?.apply?.(preference)
        switcher.open = false
        syncSelection()
      })
    })

    window.addEventListener("theme-change", syncSelection)
    syncSelection()
    switcher.dataset.ready = "true"
  }

  document.querySelectorAll("[data-theme-switcher]").forEach(initializeThemeSwitcher)
</script>

<style>
  @reference "@/styles/tailwind.css";

  .theme-switcher {
    @apply relative;
  }

  .theme-trigger {
    @apply flex cursor-pointer list-none items-center justify-center rounded-full bg-white/90 p-2 text-zinc-700 shadow-lg ring-1 ring-zinc-900/5 backdrop-blur transition hover:text-teal-500 dark:bg-zinc-800/82 dark:text-zinc-200 dark:shadow-[0_12px_32px_rgba(0,0,0,0.3)] dark:ring-white/10 dark:hover:text-teal-300;
  }

  .theme-trigger::-webkit-details-marker {
    display: none;
  }

  .theme-menu {
    @apply absolute top-full right-0 z-20 mbs-2 grid min-w-32 gap-1 rounded-2xl bg-white/95 p-1.5 shadow-xl ring-1 ring-zinc-900/10 backdrop-blur dark:bg-zinc-900/92 dark:shadow-[0_22px_60px_rgba(0,0,0,0.45)] dark:ring-white/10;
  }

  .theme-option {
    @apply flex w-full items-center justify-between rounded-xl px-3 py-2 text-left text-sm text-zinc-700 transition hover:bg-teal-500/10 hover:text-teal-600 dark:text-zinc-200 dark:hover:bg-teal-400/12 dark:hover:text-teal-200;
  }

  .theme-option[data-active="true"] {
    @apply bg-teal-500/10 text-teal-600 dark:bg-teal-400/14 dark:text-teal-200;
  }

  .theme-check {
    @apply opacity-0 transition;
  }

  .theme-option[data-active="true"] .theme-check {
    @apply opacity-100;
  }
</style>
