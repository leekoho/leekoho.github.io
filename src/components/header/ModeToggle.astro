---
import { Moon, Sun, Monitor, Check } from "@lucide/astro"

const options = [
  { value: "light", label: "Light", icon: Sun },
  { value: "dark", label: "Dark", icon: Moon },
  { value: "system", label: "System", icon: Monitor },
]
---

<details class="theme-switcher" data-theme-switcher>
  <summary class="theme-trigger">
    <Sun class="icon-light size-4" />
    <Moon class="icon-dark size-4" />
    <Monitor class="icon-system size-4" />
    <span class="sr-only">切换主题</span>
  </summary>

  <div class="theme-menu">
    {
      options.map((option) => (
        <button class="theme-option" data-theme-option={option.value} type="button">
          <option.icon class="size-4" />
          <span class="flex-1">{option.label}</span>
          <span aria-hidden="true" class="theme-check">
            <Check class="size-3.5" />
          </span>
        </button>
      ))
    }
  </div>
</details>

<script is:inline>
  const initializeThemeSwitcher = (switcher) => {
    if (!switcher || switcher.dataset.ready === "true") {
      return
    }

    const syncSelection = () => {
      const currentPreference = window.__themeController?.getPreference?.() ?? "system"
      switcher.dataset.theme = currentPreference

      switcher.querySelectorAll("[data-theme-option]").forEach((button) => {
        const isActive = button.dataset.themeOption === currentPreference
        button.dataset.active = isActive ? "true" : "false"
        button.setAttribute("aria-pressed", isActive ? "true" : "false")
      })
    }

    switcher.querySelectorAll("[data-theme-option]").forEach((button) => {
      button.addEventListener("click", () => {
        const preference = button.dataset.themeOption ?? "system"
        window.__themeController?.apply?.(preference)
        switcher.open = false
        syncSelection()
      })
    })

    window.addEventListener("theme-change", syncSelection)
    syncSelection()
    switcher.dataset.ready = "true"
  }

  document.querySelectorAll("[data-theme-switcher]").forEach(initializeThemeSwitcher)
</script>

<style>
  @reference "@/styles/tailwind.css";

  .theme-switcher {
    @apply relative;
  }

  .theme-trigger {
    @apply bg-surface/90 border-border text-foreground-soft flex cursor-pointer list-none items-center justify-center rounded-full border p-2 backdrop-blur-md transition;
    box-shadow: var(--shadow-button);
  }

  .theme-trigger::-webkit-details-marker {
    display: none;
  }

  .theme-menu {
    @apply bg-surface/95 border-border absolute top-full right-0 z-20 mbs-2 grid min-w-32 gap-1 rounded-2xl border p-1.5 backdrop-blur-lg;
    box-shadow: var(--shadow-card);
  }

  .theme-option {
    @apply text-foreground-soft flex w-full items-center justify-between gap-x-2 rounded-xl px-3 py-2 text-left text-sm transition;
  }

  .theme-option[data-active="true"] {
    @apply bg-accent/10 text-foreground;
  }

  .theme-check {
    @apply opacity-0 transition;
  }

  .theme-option[data-active="true"] .theme-check {
    @apply opacity-100;
  }

  .theme-trigger:hover,
  .theme-option:hover {
    @apply text-accent-strong;
  }

  :global(.dark) .theme-trigger {
    @apply bg-surface;
  }

  :global(.dark) .theme-menu {
    @apply bg-surface;
  }

  :global(.dark) .theme-option[data-active="true"] {
    @apply bg-accent/10;
  }

  .icon-light,
  .icon-dark,
  .icon-system {
    @apply hidden;
  }

  .theme-switcher[data-theme="light"] .icon-light {
    @apply block;
  }

  .theme-switcher[data-theme="dark"] .icon-dark {
    @apply block;
  }

  .theme-switcher[data-theme="system"] .icon-system {
    @apply block;
  }
</style>
