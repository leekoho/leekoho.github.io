---
import { Font } from "astro:assets"
import Header from "@/components/header/index.astro"
import "../styles/global.css"

interface Props {
  title?: string
  description?: string
}

const { title = "leekoho | Blog", description = "记录开发中的经验、问题拆解和一些可复用的实践。" } =
  Astro.props

const currentYear = new Date().getFullYear()
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <Font cssVariable="--font-sans" />
    <Font cssVariable="--font-mono" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="site-body">
    <div class="site-shell">
      <Header />
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <a href="https://astro.build" class="footer-powered-by" target="_blank" rel="noreferrer">
          Powered by Astro
        </a>

        <p class="footer-copyright">© {currentYear} leekoho</p>
      </footer>
    </div>
  </body>
</html>

<style>
  @reference "@/styles/tailwind.css";

  .site-body {
    @apply bg-zinc-100 dark:bg-zinc-950;
  }

  .site-shell {
    @apply mx-auto flex min-h-screen max-w-4xl flex-col bg-white ring-1 ring-zinc-300/40 2xl:max-w-5xl dark:bg-zinc-900/95 dark:shadow-[0_0_0_1px_rgba(255,255,255,0.02),0_30px_80px_rgba(0,0,0,0.45)] dark:ring-white/10;
  }

  .site-main {
    @apply flex-1;
  }

  .site-footer {
    @apply border-border mbs-8 flex items-center justify-center gap-x-2 border-t px-4 py-6 sm:px-6 lg:px-10;
  }

  .footer-powered-by {
    @apply text-muted text-sm no-underline transition;
  }

  .footer-powered-by:hover {
    @apply text-accent-strong;
  }

  .footer-copyright {
    @apply text-subtle text-sm;
  }
</style>
